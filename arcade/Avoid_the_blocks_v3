                            <span class="block text-xs font-bold uppercase tracking-wider text-emerald-700">Circuit 01</span>
                            <span class="block text-base font-bold text-slate-900">Reykjavík Grid</span>
                        </button>

                        <button onclick="selectCircuit(this, 1, ['Sector 2', 'Gateway Hub', 'The Ridge'])" 
                                class="circuit-btn w-full text-left p-3 border border-black bg-blue-50/50 hover:bg-blue-100/70 transition-colors duration-150 focus:outline-none">
                            <span class="block text-xs font-bold uppercase tracking-wider text-blue-700">Circuit 02</span>
                            <span class="block text-base font-bold text-slate-900">London Speedway</span>
                        </button>

                        <button onclick="selectCircuit(this, 2, ['Sector 3', 'Outpost Delta', 'Deep Basin'])" 
                                class="circuit-btn w-full text-left p-3 border border-black bg-amber-50/50 hover:bg-amber-100/70 transition-colors duration-150 focus:outline-none">
                            <span class="block text-xs font-bold uppercase tracking-wider text-amber-700">Circuit 03</span>
                            <span class="block text-base font-bold text-slate-900">New York Canyon</span>
                        </button>
                    </div>

                    <div class="md:col-span-2 border border-black bg-slate-100 p-4 relative flex flex-col justify-between min-h-[260px]">
                        <div class="absolute inset-0 opacity-5 pointer-events-none" style="background-image: linear-gradient(#000 1px, transparent 1px), linear-gradient(90deg, #000 1px, transparent 1px); background-size: 20px 20px;"></div>
                        
                        <div class="z-10 flex justify-between items-start">
                            <div>
                                <span class="text-xs font-mono text-slate-400 uppercase">// Live Map View</span>
                                <h4 id="active-circuit-title" class="text-lg font-bold uppercase mt-0.5 text-slate-800">Reykjavík Grid</h4>
                            </div>
                        </div>

                        <div class="my-2 border border-slate-300 relative bg-[#ebf5f0]">
                            <canvas id="mapCanvas" style="width: 100%; height: 140px; display: block;"></canvas>
                        </div>

                        <div id="destinations-container" class="z-10 flex flex-wrap gap-2 my-1">
                            <div class="bg-white border border-black px-3 py-1 text-xs font-medium text-slate-900 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">Sector 1</div>
                            <div class="bg-white border border-black px-3 py-1 text-xs font-medium text-slate-900 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">Sector 4</div>
                            <div class="bg-white border border-black px-3 py-1 text-xs font-medium text-slate-900 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">Nexus Prime</div>
                        </div>

                        <div class="z-10 flex justify-between items-center mt-2 pt-2 border-t border-slate-200">
                            <span class="text-xs font-mono text-slate-500" id="map-status">Status: Ready</span>
                            <button id="confirmCircuitBtn" class="bg-black text-white text-xs font-bold uppercase px-4 py-1.5 border border-black hover:bg-white hover:text-black transition-colors">CONFIRM VECTOR</button>
                        </div>
                    </div>
                </div>
            </div>
            <button id="backToMenuBtn" class="btn mt-4">BACK TO MENU</button>
        </div>
        
        <div id="difficultyScreen">
            <h1>DIFFICULTY</h1>
            <div id="difficultyControls">
                <div>
                    <h2>Speed & Obstacles</h2>
                    <input type="range" min="1" max="5" value="3" class="difficulty-slider" id="difficultySlider">
                    <div class="difficulty-label">
                        <span>Easy</span>
                        <span id="difficultyValue">Medium</span>
                        <span>Hard</span>
                    </div>
                </div>
                <button id="startCircuitBtn" class="btn">START CIRCUIT</button>
            </div>
        </div>
        
        <div id="endScreen">
            <h1>GAME OVER</h1>
            <h2 id="finalScore">Score: 0</h2>
            <p class="instructions">You've lost connection to the circuit</p>
            <button id="retryBtn" class="btn">TRY AGAIN</button>
            <button id="menuBtn" class="btn">MAIN MENU</button>
        </div>
        
        <div id="collisionScreen">
