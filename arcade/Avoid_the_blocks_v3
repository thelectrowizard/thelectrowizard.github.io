        }
        
        .btn {
            background-color: #000000;
            color: #FFFFFF;
            border: none;
            padding: 15px 30px;
            margin: 15px 0;
            font-size: 1.2rem;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 2px;
            transition: all 0.3s;
            width: 250px;
            border: 2px solid #000000;
            font-weight: bold;
            display: flex;
            justify-content: center;
            align-items: center;
