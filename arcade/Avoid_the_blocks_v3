                <button id="menuFromCollisionBtn" class="collision-btn">MAIN MENU</button>
                <button id="endlessFromCollisionBtn" class="collision-btn">ENDLESS MODE</button>
            </div>
        </div>

        <div id="nextCircuitScreen">
            <div id="nextCircuitPopup">
                <h2>CIRCUIT COMPLETE!</h2>
                <p>Choose your next navigation vector destination:</p>
                <button id="choiceABtn" class="collision-btn">Choice A</button>
                <button id="choiceBtn" class="collision-btn">Choice B</button>
                <div style="margin-top: 15px;">
                    <button id="backToMapFromWinBtn" class="collision-btn" style="background-color: #000000; color: #ffffff;">RETREAT TO MAP</button>
                </div>
            </div>
        </div>
        
        <div class="game-ui">
            <div id="scoreDisplay">Score: 0</div>
            <div id="lapDisplay">Lap: 0/3</div>
            <div id="levelDisplay">Level: 0/10</div>
            
            <div id="controls">
                <div>
                    <div class="control-key">W</div>
                    <div>UP</div>
                </div>
                <div>
                    <div class="control-key">A</div>
                    <div>LEFT</div>
                </div>
                <div>
                    <div class="control-key">S</div>
                    <div>DOWN</div>
                </div>
                <div>
                    <div class="control-key">D</div>
                    <div>RIGHT</div>
                </div>
            </div>
        </div>
        
        <button id="backBtn" class="hidden">BACK</button>
