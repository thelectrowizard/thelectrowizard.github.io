    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Courier New', monospace;
        }
        
        body {
            background-color: #FFFFFF; /* Ensures iframe wrapper background is white */
            color: #000000;
            overflow: hidden;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            touch-action: none;
        }
        
        #gameContainer {
            position: relative;
            width: 100%;
            max-width: 800px;
            height: 90vh;
            margin: 20px auto;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.1);
            border: 2px solid #000000;
        }
        
        canvas {
            background-color: #FFFFFF;
            display: block;
            width: 100%;
            height: 100%;
        }
        
        #titleScreen, #endScreen, #circuitScreen, #collisionScreen, #difficultyScreen, #nextCircuitScreen {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            background-color: #FFFFFF;
            z-index: 10;
            padding: 20px;
            transition: opacity 0.3s;
        }
        
        #collisionScreen {
            display: none;
