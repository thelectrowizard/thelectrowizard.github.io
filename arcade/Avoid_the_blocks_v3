        </div>
        
        <div id="circuitScreen" class="flex-col items-center justify-center p-4">
            <div class="w-full max-w-4xl mx-auto p-4 bg-slate-50 border border-black font-sans text-left">
                <div class="mb-4">
                    <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-500 mb-0.5">Circuit Selection</h3>
                    <h2 class="text-xl font-bold text-slate-900 uppercase m-0 p-0 tracking-tight">Select Your Route</h2>
