        }

        #mapCanvas {
            cursor: pointer;
        }
    </style>
</head>
<body>
    <div id="gameContainer">
        <canvas id="gameCanvas"></canvas>
        
        <div id="titleScreen">
            <h1>Avoid the Blocks V2</h1>
            <div class="track-theme">Retro Minimalist Racing</div>
            <p class="instructions">Navigate through endless tracks or complete 10 themed circuits. Avoid the black rectangles!</p>
            <button id="startBtn" class="btn pulse">ENDLESS MODE</button>
            <button id="levelBtn" class="btn">CIRCUITS</button>
            <div id="highScoreDisplay">High Score: <span id="highScoreValue">0</span></div>
            <div class="instructions">
