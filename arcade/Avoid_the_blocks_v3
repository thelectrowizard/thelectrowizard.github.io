    <script>
        // Game variables
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        const mapCanvas = document.getElementById('mapCanvas');
        const mctx = mapCanvas.getContext('2d');

        const titleScreen = document.getElementById('titleScreen');
        const endScreen = document.getElementById('endScreen');
        const circuitScreen = document.getElementById('circuitScreen');
        const collisionScreen = document.getElementById('collisionScreen');
        const difficultyScreen = document.getElementById('difficultyScreen');
        const nextCircuitScreen = document.getElementById('nextCircuitScreen');

        const startBtn = document.getElementById('startBtn');
        const levelBtn = document.getElementById('levelBtn');
        const retryBtn = document.getElementById('retryBtn');
        const menuBtn = document.getElementById('menuBtn');
        const backToMenuBtn = document.getElementById('backToMenuBtn');
        const backBtn = document.getElementById('backBtn');
        const scoreDisplay = document.getElementById('scoreDisplay');
        const lapDisplay = document.getElementById('lapDisplay');
        const levelDisplay = document.getElementById('levelDisplay');
        const finalScore = document.getElementById('finalScore');
        const restartBtn = document.getElementById('restartBtn');
        const menuFromCollisionBtn = document.getElementById('menuFromCollisionBtn');
        const endlessFromCollisionBtn = document.getElementById('endlessFromCollisionBtn');
        const difficultySlider = document.getElementById('difficultySlider');
        const startCircuitBtn = document.getElementById('startCircuitBtn');
        const confirmCircuitBtn = document.getElementById('confirmCircuitBtn');
        const difficultyValue = document.getElementById('difficultyValue');
        const highScoreValue = document.getElementById('highScoreValue');

        const choiceABtn = document.getElementById('choiceABtn');
        const choiceBtn = document.getElementById('choiceBtn');
        const backToMapFromWinBtn = document.getElementById('backToMapFromWinBtn');
        
        // Game state
        let gameState = 'title'; 
        let gameMode = 'endless'; 
        let score = 0;
        let highScore = 0;
        let lap = 0;
        let maxLaps = 3;
        let level = 0;
        let trackLength = 0;
        let playerX = 400;
        let playerY = 500; 
        let playerAngle = 0;
        let playerSpeed = 0;
        let maxSpeed = 8;
        let acceleration = 0.2;
        let deceleration = 0.1;
        let steering = 0.05;
        let trackOffset = 0;
        let trackSegments = [];
        let opponentCars = [];
        let keys = {};
        let animationId;
        let currentCircuit = 0;
        let difficulty = 3; 
        
        // Track themes - exactly 10 routes available
        const trackThemes = [
            { name: "Reykjavík Grid", connections: [1, 2], x: 0.25, y: 0.20 },
            { name: "London Speedway", connections: [0, 4], x: 0.48, y: 0.18 },
            { name: "New York Canyon", connections: [0, 3], x: 0.18, y: 0.45 },
            { name: "Cairo Junction", connections: [2, 5], x: 0.55, y: 0.50 },
            { name: "Tokyo Neon Drift", connections: [1, 6], x: 0.85, y: 0.25 },
            { name: "Sydney Horizon", connections: [3, 7], x: 0.80, y: 0.80 },
            { name: "Paris Ring", connections: [4, 8], x: 0.65, y: 0.35 },
            { name: "Rio Boulevard", connections: [5, 9], x: 0.35, y: 0.75 },
            { name: "Berlin Pass", connections: [6, 9], x: 0.70, y: 0.55 },
            { name: "Nairobi Expressway", connections: [7, 8], x: 0.45, y: 0.60 }
        ];

        let hoveredNodeIndex = null;
        
        function resizeCanvas() {
            canvas.width = canvas.clientWidth || 800;
            canvas.height = canvas.clientHeight || 600;

            mapCanvas.width = mapCanvas.clientWidth || 500;
            mapCanvas.height = mapCanvas.clientHeight || 140;
            if (gameState === 'circuit') drawMapScreen();
        }
        
        window.addEventListener('resize', resizeCanvas);
        window.addEventListener('DOMContentLoaded', () => {
            resizeCanvas();
            loadHighScore();
        });

        // Load high score
        function loadHighScore() {
            const savedScore = localStorage.getItem('circuitEchoHighScore');
            if (savedScore) {
                highScore = parseInt(savedScore);
                highScoreValue.textContent = highScore;
            }
        }
        
        // Save high score
        function saveHighScore() {
            if (score > highScore) {
                highScore = score;
                localStorage.setItem('circuitEchoHighScore', highScore);
                highScoreValue.textContent = Math.floor(highScore);
            }
        }
        
        // Initialize game
        function initGame() {
            playerX = canvas.width / 2;
            playerY = canvas.height - 100;
            playerAngle = 0;
            playerSpeed = 0;
            trackOffset = 0;
            trackSegments = [];
            opponentCars = [];
            
            const speedFactor = 1 + (difficulty - 1) * 0.5;
            maxSpeed = 8 * speedFactor;
            acceleration = 0.2 * speedFactor;
            deceleration = 0.1 * speedFactor;
            
            if (gameMode === 'endless') {
                score = 0;
                lap = 0;
                level = 0;
                generateTrack();
                generateOpponents(15);
            } else {
                generateTrack();
                generateOpponents(10 + (difficulty * 2));
            }
            
            updateScore();
        }
        
        // Generate track segments
        function generateTrack() {
            trackSegments = [];
            trackLength = gameMode === 'endless' ? 999999 : 3000; 
            
            let segmentsCount = gameMode === 'endless' ? 3000 : trackLength / 10;
            for (let i = 0; i < segmentsCount; i++) {
                const curve = Math.sin(i * 0.02) * 60;
                const x = canvas.width / 2 + curve;
                const y = i * 10;
                
                trackSegments.push({
                    x: x,
                    y: y,
                    width: 140,
                    height: 10
                });
            }
        }
        
        // Generate opponent cars
        function generateOpponents(numOpponents) {
            opponentCars = [];
            for (let i = 0; i < numOpponents; i++) {
                opponentCars.push({
                    x: Math.random() * (canvas.width - 150) + 75,
                    y: -150 - (Math.random() * 1500), 
                    width: 35,
                    height: 65,
                    speed: Math.random() * 3 + 1.5 + (difficulty * 0.4)
                });
            }
        }
        
        // Update score display
        function updateScore() {
            scoreDisplay.textContent = `Score: ${Math.floor(score)}`;
            lapDisplay.textContent = gameMode === 'endless' ? `Endless` : `Lap: ${lap}/${maxLaps}`;
            levelDisplay.textContent = gameMode === 'endless' ? `Mode: INF` : `Circuit: ${level}/10`;
        }
        
        // Draw the player car
        function drawPlayer() {
            ctx.save();
            ctx.translate(playerX, playerY);
            ctx.rotate(playerAngle);
            
            ctx.strokeStyle = '#000000';
            ctx.lineWidth = 3;
            ctx.beginPath();
            ctx.moveTo(0, -20);
            ctx.lineTo(15, 10);
            ctx.lineTo(-15, 10);
            ctx.closePath();
            ctx.stroke();
            
            ctx.beginPath();
            ctx.moveTo(-10, -5);
            ctx.lineTo(10, -5);
            ctx.stroke();
            
            ctx.beginPath();
            ctx.arc(0, 0, 8, 0, Math.PI * 2);
            ctx.stroke();
            
            ctx.restore();
        }
        
        // Draw opponent cars
        function drawOpponents() {
            opponentCars.forEach(car => {
                ctx.fillStyle = '#000000';
                ctx.fillRect(car.x, car.y, car.width, car.height);
                
                ctx.strokeStyle = '#000000';
                ctx.lineWidth = 2;
                ctx.strokeRect(car.x, car.y, car.width, car.height);
                
                ctx.fillStyle = '#000000';
                ctx.fillRect(car.x + 5, car.y + 5, car.width - 10, 10);
            });
        }
        
        // Draw track
        function drawTrack() {
            ctx.fillStyle = '#FFFFFF';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            
            ctx.strokeStyle = '#000000';
            ctx.lineWidth = 2;
            
            trackSegments.forEach((segment, index) => {
                let segmentY = segment.y - (trackOffset % (trackSegments.length * 10));
                
                if (gameMode === 'endless' && segmentY > canvas.height) {
                    segmentY -= (trackSegments.length * 10);
                }

                if (segmentY > -50 && segmentY < canvas.height + 50) {
                    ctx.beginPath();
                    ctx.moveTo(segment.x - segment.width/2, segmentY);
                    ctx.lineTo(segment.x + segment.width/2, segmentY);
                    ctx.stroke();
                    
                    if (index % 5 === 0) {
                        ctx.beginPath();
                        ctx.moveTo(segment.x - segment.width/2 + 10, segmentY);
                        ctx.lineTo(segment.x + segment.width/2 - 10, segmentY);
                        ctx.stroke();
                    }
                }
            });
        }
        
        // Draw game
        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            drawTrack();
            drawOpponents();
            drawPlayer();
        }
        
        // Update game state
        function update() {
            if (keys['ArrowUp'] || keys['w'] || keys['W']) {
                playerSpeed = Math.min(playerSpeed + acceleration, maxSpeed);
            } else if (keys['ArrowDown'] || keys['s'] || keys['S']) {
                playerSpeed = Math.max(playerSpeed - acceleration, -maxSpeed/2);
            } else {
                if (playerSpeed > 0) {
                    playerSpeed = Math.max(playerSpeed - deceleration, 0);
                } else if (playerSpeed < 0) {
                    playerSpeed = Math.min(playerSpeed + deceleration, 0);
                }
            }
            
            if (keys['ArrowLeft'] || keys['a'] || keys['A']) {
                playerAngle -= steering * (playerSpeed / maxSpeed);
                playerX = Math.max(50, playerX - 5);
            }
            
            if (keys['ArrowRight'] || keys['d'] || keys['D']) {
                playerAngle += steering * (playerSpeed / maxSpeed);
                playerX = Math.min(canvas.width - 50, playerX + 5);
            }
            
            trackOffset += playerSpeed;
            score += playerSpeed * 0.1;
            
            // Update opponents
            opponentCars.forEach(car => {
                car.y += playerSpeed - car.speed;
                
                if (car.y > canvas.height + 100) {
                    car.y = -150 - (Math.random() * 600);
                    car.x = Math.random() * (canvas.width - 150) + 75;
                }
            });

            if (gameMode === 'level') {
                if (trackOffset > trackLength) {
                    trackOffset = 0;
                    lap++;
                    if (lap >= maxLaps) {
                        handleCircuitWin();
                        return;
                    }
                }
            }
            
            checkCollisions();
            updateScore();
        }
        
        function checkCollisions() {
            const playerRect = {
                x: playerX - 15,
                y: playerY - 20,
                width: 30,
                height: 40
            };
            
            for (let i = 0; i < opponentCars.length; i++) {
                const car = opponentCars[i];
                const carRect = {
                    x: car.x,
                    y: car.y,
                    width: car.width,
                    height: car.height
                };
                
                if (rectCollision(playerRect, carRect)) {
                    playerSpeed = 0;
                    gameState = 'collision';
                    collisionScreen.style.display = 'flex';
                    saveHighScore();
                    cancelAnimationFrame(animationId);
                    return;
                }
            }
        }
        
        function rectCollision(rect1, rect2) {
            return rect1.x < rect2.x + rect2.width &&
                   rect1.x + rect1.width > rect2.x &&
                   rect1.y < rect2.y + rect2.height &&
                   rect1.y + rect1.height > rect2.y;
        }
        
        function gameLoop() {
            if (gameState === 'playing') {
                update();
                draw();
                animationId = requestAnimationFrame(gameLoop);
            }
        }
        
        function startGame() {
            gameState = 'playing';
            titleScreen.classList.add('hidden');
            circuitScreen.style.display = 'none';
            difficultyScreen.style.display = 'none';
            nextCircuitScreen.style.display = 'none';
            endScreen.style.display = 'none';
            collisionScreen.style.display = 'none';
            initGame();
            gameLoop();
        }
        
        function startLevel() {
            gameMode = 'level';
            gameState = 'circuit';
            titleScreen.classList.add('hidden');
            endScreen.style.display = 'none';
            collisionScreen.style.display = 'none';
            circuitScreen.style.display = 'flex';
            setTimeout(resizeCanvas, 50);
        }

        // --- MAP RENDER & CONTROL ENGINE ---
        function drawMapBackground() {
            mctx.fillStyle = '#ebf5f0'; 
            mctx.fillRect(0, 0, mapCanvas.width, mapCanvas.height);

            mctx.fillStyle = 'rgba(215, 230, 245, 0.9)';
            mctx.beginPath();
            mctx.arc(mapCanvas.width * 0.2, mapCanvas.height * 0.35, 60, 0, Math.PI * 2);
            mctx.fill();

            mctx.beginPath();
            mctx.arc(mapCanvas.width * 0.75, mapCanvas.height * 0.6, 70, 0, Math.PI * 2);
            mctx.fill();
        }

        function drawMapScreen() {
            if (!mapCanvas.width || !mapCanvas.height) return;
            mctx.clearRect(0, 0, mapCanvas.width, mapCanvas.height);
            drawMapBackground();

            // 1. Draw pathways
            mctx.strokeStyle = '#2c3e50';
            mctx.lineWidth = 2;
            trackThemes.forEach((theme) => {
                const startX = theme.x * mapCanvas.width;
                const startY = theme.y * mapCanvas.height;
                theme.connections.forEach(connIdx => {
                    const target = trackThemes[connIdx];
                    if (target) {
                        mctx.beginPath();
                        mctx.moveTo(startX, startY);
                        mctx.lineTo(target.x * mapCanvas.width, target.y * mapCanvas.height);
                        mctx.stroke();
                    }
                });
            });

            // 2. Draw Circuit Nodes
            trackThemes.forEach((theme, index) => {
                const nodeX = theme.x * mapCanvas.width;
                const nodeY = theme.y * mapCanvas.height;
                const isHovered = (hoveredNodeIndex === index) || (currentCircuit === index);

                mctx.fillStyle = isHovered ? '#ffffff' : '#000000';
                mctx.strokeStyle = '#000000';
                mctx.lineWidth = 2;

                mctx.beginPath();
                mctx.arc(nodeX, nodeY, isHovered ? 10 : 7, 0, Math.PI * 2);
                mctx.fill();
                mctx.stroke();

                mctx.fillStyle = isHovered ? '#000000' : '#ffffff';
                mctx.beginPath();
                mctx.arc(nodeX, nodeY, 3, 0, Math.PI * 2);
                mctx.fill();

                mctx.fillStyle = '#000000';
                mctx.font = 'bold 9px Courier New';
                mctx.textAlign = 'center';
                mctx.fillText(theme.name.split(' ')[0], nodeX, nodeY - 12);
            });
        }

        // UI Interactive Sync Strategy function
        window.selectCircuit = function(element, themeIndex, destinations) {
            currentCircuit = themeIndex;
            const circuitName = trackThemes[themeIndex].name;
            
            const buttons = document.querySelectorAll('.circuit-btn');
            buttons.forEach(btn => {
                btn.classList.remove('border-2', 'ring-2', 'ring-black', 'ring-offset-2');
                btn.classList.add('border');
            });

            if(element) {
                element.classList.remove('border');
                element.classList.add('border-2', 'ring-2', 'ring-black', 'ring-offset-2');
            }
            
            document.getElementById('active-circuit-title').innerText = circuitName;
            
            const container = document.getElementById('destinations-container');
            container.innerHTML = ''; 
            
            destinations.forEach(dest => {
                const box = document.createElement('div');
                box.className = "bg-white border border-black px-3 py-1 text-xs font-medium text-slate-900 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]";
                box.innerText = dest;
                container.appendChild(box);
            });

            document.getElementById('map-status').innerText = `Selected: ${circuitName.toUpperCase()}`;
            drawMapScreen();
        };

        mapCanvas.addEventListener('mousemove', (e) => {
            if (gameState !== 'circuit') return;
            const rect = mapCanvas.getBoundingClientRect();
            const mouseX = e.clientX - rect.left;
            const mouseY = e.clientY - rect.top;

            let lastHovered = hoveredNodeIndex;
            hoveredNodeIndex = null;

            for (let i = 0; i < trackThemes.length; i++) {
                const node = trackThemes[i];
                const actualX = (node.x * mapCanvas.width) * (rect.width / mapCanvas.width);
                const canvasMouseX = mouseX * (mapCanvas.width / rect.width);
                const canvasMouseY = mouseY * (mapCanvas.height / rect.height);
                
                if (Math.hypot(canvasMouseX - (node.x * mapCanvas.width), canvasMouseY - (node.y * mapCanvas.height)) < 15) {
                    hoveredNodeIndex = i;
                    break;
                }
            }
            if (lastHovered !== hoveredNodeIndex) drawMapScreen();
        });

        mapCanvas.addEventListener('click', () => {
            if (gameState === 'circuit' && hoveredNodeIndex !== null) {
                const randomSectors = [`Sector ${hoveredNodeIndex+1}`, `Hub ${hoveredNodeIndex*2}`, `Vector Point`];
                selectCircuit(null, hoveredNodeIndex, randomSectors);
            }
        });

        function handleCircuitWin() {
            gameState = 'nextChoose';
            cancelAnimationFrame(animationId);
            saveHighScore();
            nextCircuitScreen.style.display = 'flex';
            
            const currentConnections = trackThemes[currentCircuit].connections;
            const optionA = trackThemes[currentConnections[0]] || trackThemes[0];
            const optionB = trackThemes[currentConnections[1]] || trackThemes[1];

            choiceABtn.textContent = optionA.name;
            choiceABtn.onclick = () => { selectNextVector(currentConnections[0] || 0); };
            
            choiceBtn.textContent = optionB.name;
            choiceBtn.onclick = () => { selectNextVector(currentConnections[1] || 1); };
        }

        function selectNextVector(nextIndex) {
            currentCircuit = nextIndex;
            level = nextIndex;
            lap = 0;
            score += 500; 
            nextCircuitScreen.style.display = 'none';
            gameState = 'playing';
            initGame();
            gameLoop();
        }

        // Global Action Event Listeners
        startBtn.addEventListener('click', () => {
            gameMode = 'endless';
            gameState = 'difficulty';
            titleScreen.classList.add('hidden');
            difficultyScreen.style.display = 'flex';
        });

        levelBtn.addEventListener('click', startLevel);
        
        confirmCircuitBtn.addEventListener('click', () => {
            level = currentCircuit;
            lap = 0;
            gameState = 'difficulty';
            circuitScreen.style.display = 'none';
            difficultyScreen.style.display = 'flex';
        });

        startCircuitBtn.addEventListener('click', startGame);

        difficultySlider.addEventListener('input', (e) => {
            difficulty = parseInt(e.target.value);
            const labels = ["Very Easy", "Easy", "Medium", "Hard", "Hyper"];
            difficultyValue.textContent = labels[difficulty - 1];
        });

        retryBtn.addEventListener('click', startGame);
        
        restartBtn.addEventListener('click', () => {
            collisionScreen.style.display = 'none';
            startGame();
        });

        const resetToMenu = () => {
            gameState = 'title';
            titleScreen.classList.remove('hidden');
            circuitScreen.style.display = 'none';
            difficultyScreen.style.display = 'none';
            endScreen.style.display = 'none';
            collisionScreen.style.display = 'none';
            nextCircuitScreen.style.display = 'none';
            loadHighScore();
        };

        menuBtn.addEventListener('click', resetToMenu);
        backToMenuBtn.addEventListener('click', resetToMenu);
        menuFromCollisionBtn.addEventListener('click', resetToMenu);
        backToMapFromWinBtn.addEventListener('click', startLevel);

        endlessFromCollisionBtn.addEventListener('click', () => {
            gameMode = 'endless';
            collisionScreen.style.display = 'none';
            startGame();
        });

        // Input polling listeners
        window.addEventListener('keydown', (e) => { keys[e.key] = true; });
        window.addEventListener('keyup', (e) => { keys[e.key] = false; });
    </script>
</body>
